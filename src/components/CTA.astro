---
import Button from "./Button.astro";
---
<section class='text-center py-24 px-8 border-t border-line'>
    <h2 class='text-3xl font-bold mb-3'>Ready to protect your frontend?</h2>
    <p class='text-fg-3 mb-8'>
        Works with any static framework — Vite, Astro, Next.js, plain HTML.
    </p>
    <div class='flex gap-3 justify-center flex-col items-center md:flex-row'>
        <Button href='/getting-started/getting-started/'>Get started →</Button>
        <Button href='/getting-started/overview/' variant='secondary'>Learn more</Button>
    </div>
</section>
