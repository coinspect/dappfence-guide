---
interface Props {
    number: string;
}
const { number } = Astro.props;
---

<div class='flex gap-6 p-6 px-7 items-start'>
    <span class='font-mono text-2xl font-bold text-green/70 leading-snug min-w-[2.2rem] shrink-0'
        >{number}</span
    >
    <div class='text-base leading-relaxed text-fg-2'><slot /></div>
</div>
