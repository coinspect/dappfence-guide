---
import HowItWorksStep from "./HowItWorksStep.astro";
import { HOW_IT_WORKS } from "../config";
---
<section class='max-w-7xl mx-auto py-16 px-6 md:px-8'>
    <h2 class='section-heading'>How it works</h2>
    <div>
        {HOW_IT_WORKS.map(({ number, heading, body }) => (
            <HowItWorksStep number={number}>
                <strong>{heading}</strong> {body}
            </HowItWorksStep>
        ))}
    </div>
</section>
