---
import Button from "./Button.astro";
---
<section
    class="relative min-h-[70vh] md:min-h-[88vh] flex items-center bg-[url('/hero-image.png')] bg-cover bg-position-[right_center] md:bg-center">
    <div
        class='absolute inset-0'
        style='background: linear-gradient(to right, var(--sl-color-hero-overlay) 35%, transparent 100%)'>
    </div>
    <div
        class='absolute inset-0'
        style='background: linear-gradient(to bottom, transparent 50%, var(--sl-color-bg) 100%)'>
    </div>
    <div
        class='relative z-10 py-16 px-6 max-w-155 md:py-20 md:px-8 md:ml-[max(2rem,calc((100vw-var(--container-width))/2))]'>
        <div
            class='inline-block mb-6 px-3 py-1 border border-green-dim bg-green-bg text-green rounded-full text-xs font-mono tracking-wider'>
            Frontend Security
        </div>
        <h1
            class='text-[clamp(1.9rem,4vw,3rem)] font-bold leading-[1.2] tracking-[-0.02em] mb-5'>
            Every asset your app loads — verified at runtime, blocked if tampered.
        </h1>
        <p class='text-base text-fg-3 leading-relaxed max-w-[52ch] mb-8'>
            DappFence is a Service Worker that intercepts every request your app makes
            and checks it against a cryptographically signed manifest. One script tag.
            No server changes. No trusted CDN required.
        </p>
        <div class='flex gap-3 flex-wrap'>
            <Button href='/getting-started/getting-started/'>Get started →</Button>
            <Button href='/getting-started/overview/' variant='secondary'>Learn more</Button>
        </div>
    </div>
</section>
